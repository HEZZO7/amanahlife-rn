{
  "expo": {
    "name": "AmanahLife",
    "slug": "amanahlife",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "amanahlife",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1F17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.linkoranet.amanahlife",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AmanahLife uses your location for accurate prayer times and Qibla direction.",
        "NSCameraUsageDescription": "AmanahLife uses the camera to scan receipts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1F17"
      },
      "package": "com.linkoranet.amanahlife",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AmanahLife needs your location for prayer times and Qibla direction."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1FC7C1",
          "sounds": []
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f0bac58-8ce6-4805-bea4-57a3f26d0fbf"
      }
    },
    "owner": "linkoranet"
  }
}
